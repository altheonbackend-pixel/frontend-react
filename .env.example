# ============================================================
# Altheon Connect — Frontend Environment Variables
# Copy this file to .env.local (development) or set in Vercel
# ============================================================

# --- Required ---
VITE_API_URL=                      # Backend base URL, e.g. https://api.altheon.com
                                   # The /api/v1/ path is appended by src/config.ts

# --- Monitoring (optional) ---
VITE_SENTRY_DSN=                   # Sentry DSN for frontend error monitoring
VITE_ENV=production                # Used in Sentry environment tagging
